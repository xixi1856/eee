# ==============================================================
# Qwen / DashScope API
# ==============================================================
# Get your key at: https://dashscope.aliyun.com/
LLM_API_KEY=sk-your-dashscope-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==============================================================
# Model names (defaults match src/rag_mvp/config.py Settings)
# ==============================================================
# LLM_MODEL=qwen-plus-2025-04-28
# REFINE_MODEL=qwen-long
# VISION_MODEL=qwen-vl-max
#
# --- Embeddings (EMBEDDING_MODE selects backend; EMBEDDING_MODEL is interpreted in that namespace) ---
# Defaults in code: openai_compatible + text-embedding-v1 + EMBEDDING_DIM=1024 (DashScope compatible-mode; must match PG vector(N)).
# EMBEDDING_MODE=openai_compatible   # openai_compatible (default) | ollama
# Aliases normalized to openai_compatible: dashscope | openai | compatible
#
# --- Mode: openai_compatible (default — DashScope text-embedding-v1) ---
# Uses LLM_BASE_URL + LLM_API_KEY by default, or overrides:
# EMBEDDING_BASE_URL=          # optional; empty = LLM_BASE_URL
# EMBEDDING_API_KEY=           # optional; empty = LLM_API_KEY
# EMBEDDING_MODEL=text-embedding-v1
# EMBEDDING_DIM=1024           # must match provider output + Postgres vector columns
#
# --- Mode: ollama (local) ---
# Course indexing FAIL FAST if Ollama is not reachable (GET /api/tags).
# Start Ollama and run: ollama pull bge-m3   (must match EMBEDDING_DIM / Postgres vector(N))
# EMBEDDING_MODE=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_DIM=1024
# OLLAMA_API_KEY=            # optional; Ollama Cloud / authenticated hosts
#
# LightRAG ingest tuning (rag_mvp passes these into LightRAG from Settings; restart worker after change)
# EMBEDDING_BATCH_NUM=3       # texts per embed batch (default 3; lower for slower local Ollama)
# CHUNK_SIZE=1000             # max tokens per text chunk (default 1000)
# CHUNK_OVERLAP_SIZE=100      # overlap between chunks (default 100)
# EMBEDDING_TIMEOUT=120       # seconds; LightRAG uses this for embedding func timeout (worker cap scales with it)
#
# --- Course surrogate ingest: optional VLM summary for images (skip_kg + full multimodal; edu-rag-worker reads repo .env) ---
# Default off. When true, calls VISION_MODEL per image before text embedding (extra latency + API cost).
# INGEST_SURROGATE_IMAGE_VLM=false
# INGEST_SURROGATE_IMAGE_VLM_MAX_TOKENS=400
# INGEST_SURROGATE_IMAGE_VLM_MAX_CONCURRENCY=2
# INGEST_SURROGATE_IMAGE_VLM_MAX_BYTES=4000000
# INGEST_SURROGATE_IMAGE_VLM_SYSTEM_PROMPT=...
# INGEST_SURROGATE_IMAGE_VLM_USER_PROMPT=...
#
# Do NOT set EMBEDDING_MODEL=text-embedding-v1 while EMBEDDING_MODE=ollama — Ollama expects local tags (e.g. bge-m3).
# EMBEDDING_MAX_TOKENS=8192
# RAG_SKIP_OLLAMA_PREFLIGHT=1   # optional; skip Ollama GET /api/tags only (ollama mode; read in llm.py)
# RAG_SKIP_EMBEDDING_PREFLIGHT=1  # optional; skip all embedding pref lights (ollama + openai_compatible)
# If HTTP_PROXY points at a local proxy (e.g. Clash) that is off, rag_mvp auto-appends
# 127.0.0.1,localhost,::1 to NO_PROXY so Ollama/embeddings bypass the proxy. Override:
# RAG_DISABLE_LOOPBACK_NO_PROXY=1

# ==============================================================
# LLM generation parameters
# ==============================================================
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.1
# LLM_EXTRA_BODY={"enable_thinking": false}  # For qwen-plus/pro: disable thinking mode to improve latency

# ==============================================================
# Storage paths
# ==============================================================
# WORKING_DIR=rag_storage
# OUTPUT_DIR=output/parsed
# TRANSCRIPT_OUTPUT_DIR=output/transcripts

# ==============================================================
# Video → Whisper (CLI `rag video-ingest`; requires `uv sync --extra video` + ffmpeg)
# ==============================================================
# FFMPEG_PATH=ffmpeg
# WHISPER_MODEL_SIZE=base
# WHISPER_DEVICE=cpu
# WHISPER_LANGUAGE=            # empty = auto language detection (faster-whisper)

# ==============================================================
# Video structured summary (before RAG ingest; LLM segments → .summary.md)
# ==============================================================
# VIDEO_SUMMARY_TARGET_SEGMENT_SECONDS=300
# VIDEO_SUMMARY_MAX_SEGMENT_SECONDS=600
# VIDEO_SUMMARY_LLM_MODEL=     # empty = use REFINE_MODEL
# VIDEO_SUMMARY_SYSTEM_PROMPT= # empty = built-in prompt in video_transcript_summary.py

# ==============================================================
# MinerU parsing options
# ==============================================================
# MINERU_BACKEND=pipeline      # pipeline (CPU) | hybrid-auto-engine | vlm-auto-engine
# MINERU_DEVICE=cpu            # cpu | cuda | cuda:0 | mps
# MINERU_SOURCE=modelscope     # modelscope | huggingface | local
# MINERU_LANG=ch               # OCR language: ch | en | ja | ...

# ==============================================================
# MinerU Cloud API (mineru.net — 精准解析 v4)
# Obtain a token at: https://mineru.net/apiManage/token
# Leave MINERU_CLOUD_API_KEY empty to skip cloud and use local MinerU only.
# ==============================================================
MINERU_CLOUD_API_KEY=your-mineru-cloud-token-here
# MINERU_CLOUD_ENABLED=true                 # true (default) | false — disable cloud entirely
# MINERU_CLOUD_MODEL_VERSION=vlm            # pipeline | vlm (recommended) | MinerU-HTML
# MINERU_CLOUD_TIMEOUT=600                  # seconds to wait for cloud task (default: 600)
# MINERU_CLOUD_POLL_INTERVAL=5              # polling interval in seconds (default: 5)
# MINERU_CLOUD_FALLBACK_LOCAL=true          # fall back to local MinerU on cloud error

# ==============================================================
# RAGAnything parser (used when cloud is disabled or falls back)
# ==============================================================
# PARSER=mineru                # mineru | docling | paddleocr

# ==============================================================
# Proxy (used by wikipedia tool; leave empty to disable)
# ==============================================================
# HTTP_PROXY=

# ==============================================================
# Concurrency limits – lower if you hit 429s or PostgreSQL pool / asyncpg races
# ==============================================================
# LLM_MAX_ASYNC=4             # parallel LLM (chat) calls      (default: 4)
# EMBEDDING_MAX_ASYNC=2      # parallel embedding calls       (default: 2)
# MAX_PARALLEL_INSERT=1       # parallel document inserts      (default: 1)
# PARSE_METHOD=auto            # auto | ocr | txt

# ==============================================================
# Image filtering (skip decorative images before full vision analysis)
# ==============================================================
# ENABLE_IMAGE_FILTER=false
# IMAGE_FILTER_PROMPT=        # optional override; long default string lives in config.py Settings

# ==============================================================
# LightRAG graph storage
# ==============================================================
# GRAPH_STORAGE=NetworkXStorage   # NetworkXStorage | PGGraphStorage (needs Apache AGE)

# ==============================================================
# Optional LightRAG rerank (cohere | jina | ali / DashScope text rerank)
# ==============================================================
# RERANK_BINDING=
# RERANK_MODEL=
# RERANK_BASE_URL=
# RERANK_API_KEY=
# QUERY_ENABLE_RERANK=true

# ==============================================================
# Web search (optional tooling)
# ==============================================================
# TAVILY_API_KEY=


REDIS_URL = "redis://localhost:6379"
DATABASE_URL = "postgresql://edu:edu@localhost:5432/edu_platform?schema=public"