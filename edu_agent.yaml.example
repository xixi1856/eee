# Copy to repo root as `edu_agent.yaml` (or pass a path via load_settings in custom entrypoints).
# Values can use ${ENV_VAR} placeholders; see config_loader.resolve_env_vars.

agent:
  workspace: .
  provider: dashscope
  model: qwen-plus-2025-04-28
  temperature: 0.1
  max_tokens: 4096
  max_iterations: 20
  skills_dir: skills
  # OpenAI-compatible models (Qwen / DeepSeek): pass provider-specific fields via extra_body.
  # For qwen-plus/pro to reduce latency, you can disable thinking mode:
  # llm_extra_body:
  #   enable_thinking: false
  # DeepSeek V4 example:
  # llm_extra_body:
  #   thinking:
  #     type: disabled

providers:
  dashscope:
    api_key: ${LLM_API_KEY}
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
  # ollama:
  #   api_key: ollama
  #   base_url: http://127.0.0.1:11434/v1

tools:
  tavily_api_key: ""
  http_proxy: ""
  ollama_api_key: ""

runtime:
  log_level: INFO
  default_timezone: UTC
  env: dev
  gateway:
    host: "127.0.0.1"
    port: 8765
    require_http_key: false
    api_key: ""
  channels:
    http_enabled: true
    websocket_enabled: true
    # Personal WeChat (ilinkai; defaults match HKUDS nanobot — no base_url required).
    # 1) uv run edu channels login weixin
    # 2) enabled: true; optional allow_from: ["*"] or your ilink user id
    weixin:
      enabled: false
      # token: ""  # optional; else read from .edu_agent/weixin/account.json
      # state_dir: ".edu_agent/weixin"
      # allow_from: ["*"]
      # route_tag: ""
    # Feishu / Lark enterprise bot (WebSocket long connection; requires dependency ``lark-oapi``).
    # Console: custom app → Bot → subscribe ``im.message.receive_v1`` → long connection mode.
    feishu:
      enabled: false
      # app_id: ""
      # app_secret: ""
      # encrypt_key: ""           # from app console if event encryption is on
      # verification_token: ""      # from app console (can be empty if encryption off)
      # domain: "https://open.feishu.cn"   # or https://open.larksuite.com (intl)
      # allow_from: ["*"]          # open_id allowlist; "*" allows all
      # route_tag: ""
