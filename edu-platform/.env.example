# =============================================================================
# edu-platform — env vars used by this Next.js app
# Sources: prisma/schema.prisma, prisma/seed.ts, lib/config.ts,
#   lib/agent/setup.ts, lib/agent/tools/*, lib/services/assignmentService.ts,
#   app/api/v1/courses/[courseId]/knowledge-graph-html/route.ts
# =============================================================================

# --- PostgreSQL (Prisma; required for migrate / runtime) ---
# With docker-compose.yml in this folder:
#   postgresql://edu:edu@localhost:5432/edu_platform?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edu_platform?schema=public"

# --- JWT & cookies (lib/config.ts) ---
# JWT signing — min 16 chars in code; use 32+ random bytes in production
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
# JWT_ISS="edu-platform"

# Access / refresh / channel token TTL (seconds); defaults shown
# JWT_ACCESS_TTL_SEC=86400
# JWT_REFRESH_TTL_SEC=604800
# JWT_CHANNEL_TTL_SEC=3600

# --- Admin bootstrap (prisma db seed) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_PASSWORD="set-a-strong-password-here"

# --- Internal API (lib/config.ts getInternalApiKeyOrNull) ---
# Min 16 chars. Used as X-Internal-Key for /api/v1/internal/* routes.
# If unset, GET /api/v1/internal/course-rag-access returns 503.
INTERNAL_API_KEY="change-me-internal-api-key-16+"

# --- MinIO / S3-compatible (lib/config.ts getMinioConfig) ---
# Required for material uploads. With docker-compose defaults:
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_minio_minio
MINIO_BUCKET=edu-materials
MINIO_USE_SSL=false
# MINIO_REGION=us-east-1

# --- Redis (lib/config.ts; required for RAG task stream and rate limiting) ---
REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=edu:

# --- LLM (lib/agent/llm-registry.ts; role-based multi-model configuration) ---
# Default / fallback provider (used by memory extraction and vision if not overridden)
LLM_API_KEY="sk-your-api-key-here"
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL="qwen-plus-2025-04-28"
# LLM_AUXILIARY_MODEL=   # for memory extraction; defaults to LLM_MODEL

# Chat & assignment role — main conversation model (e.g. DeepSeek)
# Falls back to LLM_API_KEY / LLM_BASE_URL / LLM_MODEL when unset.
# LLM_CHAT_API_KEY="sk-your-deepseek-key"
# LLM_CHAT_BASE_URL="https://api.deepseek.com/v1"
# LLM_CHAT_MODEL="deepseek-v4-pro"

# Title generation role — cheap/fast model (inherits CHAT key/url by default)
# LLM_TITLE_MODEL="deepseek-v4-flash"

# Vision role — image understanding model (e.g. Qwen VL)
# Falls back to LLM_API_KEY / LLM_BASE_URL / LLM_MODEL when unset.
# LLM_VISION_API_KEY="sk-your-qwen-key"
# LLM_VISION_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# LLM_VISION_MODEL="qwen3.6-plus"

# Agent tuning (optional)
# AGENT_MAX_ITERATIONS=8
# AGENT_MAX_CONTEXT_TOKENS=120000

# --- RAG Service (lib/agent/setup.ts, lib/services/assignmentService.ts) ---
# Python rag-service must be running. Key must match RAG_SERVICE_API_KEY in repo-root .env.
RAG_SERVICE_URL=http://localhost:8001
RAG_SERVICE_API_KEY="change-me-rag-service-key"
# When running rag-service via docker compose, prefer service-name URLs:
# RAG_SERVICE_DATABASE_URL=postgresql://edu:edu@postgres:5432/edu_platform?schema=public
# Optional (only if you need explicit LightRAG DSN):
# LightRAG uses its own isolated database to avoid Prisma migration drift:
# RAG_SERVICE_LIGHTRAG_PG_DSN=postgresql://edu:edu@postgres:5432/edu_lightrag
# Local dev override (rag-service runs outside Docker):
# LIGHTRAG_PG_DSN=postgresql://edu:edu@localhost:5432/edu_lightrag

# --- RAG Redis Stream (lib/config.ts; producer: Next.js XADD; consumer: edu-rag-worker) ---
# Defaults shown; only set if you need non-standard names.
# RAG_TASK_STREAM_NAME=edu:rag:tasks:stream
# RAG_TASK_STREAM_GROUP=edu-rag-workers
# RAG_TASK_CONSUMER_NAME=edu-next-1
# RAG_MATERIAL_STALE_SEC=1800

# --- Cron worker stream (scripts/cron-worker.ts) ---
# CRON_STREAM_NAME=edu:cron:stream
# CRON_STREAM_GROUP=edu-cron-workers
# When running cron-worker via docker compose, prefer service-name URLs:
# CRON_WORKER_DATABASE_URL=postgresql://edu:edu@postgres:5432/edu_platform?schema=public
# CRON_WORKER_REDIS_URL=redis://redis:6379
# CRON_WORKER_RAG_SERVICE_URL=http://rag-service:8001

# --- Upload limits ---
# MATERIAL_MAX_UPLOAD_BYTES=52428800   # default 50 MiB

# --- Reverse proxy (lib/config.ts getTrustProxyHops) ---
# Number of trusted reverse proxies in front of Next.js (for client IP via X-Forwarded-For).
# TRUST_PROXY_HOPS=0

# --- LightRAG PG table names (knowledge-graph-html route only) ---
# Override only if edu-rag-worker uses a non-default embedding dim / table suffix.
# LIGHTRAG_ENTITY_TABLE=lightrag_vdb_entity_bge_m3_1024d
# LIGHTRAG_RELATION_TABLE=lightrag_vdb_relation_bge_m3_1024d
