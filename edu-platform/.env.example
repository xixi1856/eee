# =============================================================================
# edu-platform — env vars used by this Next.js app
# Sources: prisma/schema.prisma, prisma/seed.ts, lib/config.ts,
#   app/api/v1/courses/[courseId]/knowledge-graph-html/route.ts,
#   lib/services/assignmentService.ts (duplicate stream name default)
# =============================================================================

# --- PostgreSQL (Prisma; required for migrate / runtime) ---
# With repo docker-compose.yml in this folder:
#   postgresql://edu:edu@localhost:5432/edu_platform?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edu_platform?schema=public"

# --- JWT & cookies (lib/config.ts) ---
# JWT signing — min 16 chars in code; use 32+ random bytes in production
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_ISS="edu-platform"

# Access / refresh / channel token TTL (seconds)
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
JWT_CHANNEL_TTL_SEC=3600

# HMAC key for credential codes — min 16 chars; must differ from JWT_SECRET
CREDENTIAL_CODE_PEPPER="change-me-credential-pepper-16+"

# Agent bind header X-Platform-Bind-Key — min 16 chars; share only with Agent
BIND_CREDENTIAL_API_KEY="change-me-bind-api-key-16+"

# Optional: signing secret for short-lived bind challenge JWTs (min 16 chars).
# If unset, JWT_SECRET is used (lib/config.ts getBindChallengeSecret).
# BIND_CHALLENGE_SECRET=

# --- Redis (lib/config.ts) ---
# Required for bind/start + bind/complete challenge store; recommended for bind rate limits.
# If unset, bind/start returns 503; bind rate limit falls back to Postgres.
# With docker-compose in this folder: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# Optional key prefix for multi-tenant Redis (default "edu:")
# REDIS_KEY_PREFIX=edu:

# Bind challenge TTL (seconds), default 600
# BIND_CHALLENGE_TTL_SEC=600

# Trusted reverse-proxy hops for client IP (0 = do not trust X-Forwarded-For)
# TRUST_PROXY_HOPS=0

# --- Rate limits & self-service credential (lib/config.ts) ---
CREDENTIAL_GEN_LIMIT_PER_HOUR=10
BIND_FAIL_LIMIT_PER_HOUR=20
BIND_BAN_MINUTES=15
SELF_CREDENTIAL_MAX_EXPIRES_MINUTES=30

# --- Admin bootstrap (prisma db seed) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_PASSWORD="set-a-strong-password-here"

# --- Internal API (lib/config.ts getInternalApiKeyOrNull) ---
# Min 16 chars. Agent uses header X-Internal-Key with the same value (often via EDU_PLATFORM_INTERNAL_API_KEY).
# If unset, GET /api/v1/internal/course-rag-access returns 503.
INTERNAL_API_KEY="change-me-internal-api-key-16+"

# --- MinIO / S3-compatible (lib/config.ts getMinioConfig) ---
# Required for material uploads: MINIO_ENDPOINT, MINIO_ACCESS_KEY, MINIO_SECRET_KEY, MINIO_BUCKET.
# With docker-compose in this folder:
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=minio
# MINIO_SECRET_KEY=minio_minio_minio
# MINIO_BUCKET=edu-materials
# MINIO_USE_SSL=false
# MINIO_REGION=us-east-1

# --- RAG Redis Stream (lib/config.ts; producer: Next XADD; consumer: edu-rag-worker) ---
# RAG_STREAM_CLAIM_IDLE_MS is read by the Python worker only, not Next.js.
# RAG_TASK_STREAM_NAME=edu:rag:tasks:stream
# RAG_TASK_STREAM_GROUP=edu-rag-workers
# RAG_TASK_CONSUMER_NAME=edu-next-1
# RAG_STREAM_CLAIM_IDLE_MS=300000
# RAG_MATERIAL_STALE_SEC=1800
#
# Optional image VLM summaries during course ingest (Python worker only; set in repo-root .env for edu-rag-worker):
# INGEST_SURROGATE_IMAGE_VLM=false
# See repo-root .env.example for INGEST_SURROGATE_IMAGE_VLM_* knobs.

# Max upload size per file (bytes), default 50 MiB
# MATERIAL_MAX_UPLOAD_BYTES=52428800

# --- Agent ↔ platform (Phase 7 course RAG HTTP) ---
# Agent process env (not read by Next): base URL of this app + same secret as INTERNAL_API_KEY.
# EDU_PLATFORM_BASE_URL=http://127.0.0.1:3000
# EDU_PLATFORM_INTERNAL_API_KEY=<same as INTERNAL_API_KEY>

# --- LightRAG PG table names (knowledge-graph-html route only) ---
# Defaults match Ollama bge-m3 @ 1024d. If repo-root rag_mvp uses different embedding / table suffix,
# set these to the actual LightRAG entity/relation table names in the same DB as DATABASE_URL.
# Embedding dim is configured in repo root src/rag_mvp/config.py (EMBEDDING_DIM), not in edu-platform.
# LIGHTRAG_ENTITY_TABLE=lightrag_vdb_entity_bge_m3_1024d
# LIGHTRAG_RELATION_TABLE=lightrag_vdb_relation_bge_m3_1024d

# --- Phase 8: course chat → EduAgent HTTP (lib/config.ts) ---
# Required when using course chat: same host:port as `uv run edu-gateway`.
# EDU_AGENT_BASE_URL=http://127.0.0.1:8765
# Optional Bearer when Agent HTTP auth is enabled (min 8 chars if set)
# EDU_AGENT_API_KEY=
