generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MaterialStatus {
  UPLOADED
  PARSING
  PARSED
  INDEXING
  READY
  FAILED
}

enum MaterialPreviewPdfStatus {
  NA
  PENDING
  READY
  FAILED
}

enum AssignmentStatus {
  GENERATING
  FAILED
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @map("username")
  email        String   @unique @map("email")
  passwordHash String   @map("password_hash")
  role         UserRole @map("role")
  realName     String?  @map("real_name")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  isActive     Boolean  @default(true) @map("is_active")

  /// When false, chat still works but QaLog rows are not created (B3 privacy).
  qaCollectionEnabled            Boolean   @default(true) @map("qa_collection_enabled")
  qaCollectionNoticeAcceptedAt   DateTime? @map("qa_collection_notice_accepted_at")

  refreshTokens       RefreshToken[]
  teacherCourses      Course[]             @relation("TeacherCourses")
  courseCollaborations CourseCollaborator[] @relation("CourseCollaborators")
  courseEnrollments   CourseEnrollment[]   @relation("StudentEnrollments")
  qaLogs                    QaLog[]                    @relation("QaLogStudent")
  courseChatSessions        CourseChatSession[]
  qaCenterSessions          QaCenterSession[]
  chatThreadTitleOverrides  ChatThreadTitleOverride[]
  assignments               Assignment[]
  learningProfile           UserLearningProfile?
  memoryFacts               UserMemoryFact[]
  memoryConcepts            UserMemoryConcept[]
  cronJobs                  CronJob[]

  @@map("users")
}

model Course {
  id            String       @id @default(uuid()) @db.Uuid
  teacherId     String       @map("teacher_id") @db.Uuid
  name          String       @map("name")
  description   String?      @map("description")
  coverImageUrl String?      @map("cover_image_url")
  status        CourseStatus @default(DRAFT) @map("status")
  shareCode     String?      @unique @map("share_code")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  isDeleted     Boolean      @default(false) @map("is_deleted")

  teacher         User                   @relation("TeacherCourses", fields: [teacherId], references: [id], onDelete: Cascade)
  collaborators   CourseCollaborator[]
  enrollments     CourseEnrollment[]
  lessons     Lesson[]
  materials   Material[]
  qaLogs      QaLog[]
  chatSessions CourseChatSession[]
  assignments  Assignment[]

  @@index([teacherId])
  @@map("courses")
}

model CourseCollaborator {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation("CourseCollaborators", fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([courseId, teacherId])
  @@index([teacherId])
  @@map("course_collaborators")
}

model Lesson {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  title       String   @map("title")
  description String?  @map("description")
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isDeleted   Boolean  @default(false) @map("is_deleted")

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials Material[]
  qaLogs    QaLog[]

  @@index([courseId])
  @@map("lessons")
}

model CourseEnrollment {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([studentId])
  @@map("course_enrollments")
}

model Material {
  id                 String         @id @default(uuid()) @db.Uuid
  courseId           String         @map("course_id") @db.Uuid
  lessonId           String?        @map("lesson_id") @db.Uuid
  originalFilename   String         @map("original_filename")
  fileType           String         @map("file_type")
  fileSize           Int            @map("file_size")
  minioPath          String         @map("minio_path")
  previewPdfStatus   MaterialPreviewPdfStatus @default(NA) @map("preview_pdf_status")
  status             MaterialStatus @default(UPLOADED) @map("status")
  statusMessage      String?        @map("status_message")
  indexedChunkCount  Int            @default(0) @map("indexed_chunk_count")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  isDeleted          Boolean        @default(false) @map("is_deleted")

  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  images             MaterialImage[]
  chunkPageMappings  ChunkPageMapping[]

  @@index([courseId, status])
  @@map("materials")
}

model MaterialImage {
  id         String   @id @default(uuid()) @db.Uuid
  materialId String   @map("material_id") @db.Uuid
  pageIdx    Int      @map("page_idx")
  minioUrl   String   @map("minio_url")
  createdAt  DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@map("material_images")
}

/// Maps LightRAG chunk IDs to the source page they were extracted from.
/// Populated during material indexing so citation panels can show only the relevant page image.
model ChunkPageMapping {
  id         String @id @default(uuid()) @db.Uuid
  materialId String @map("material_id") @db.Uuid
  chunkId    String @map("chunk_id") @db.VarChar(255)
  pageIdx    Int    @map("page_idx")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([materialId, chunkId])
  @@index([materialId])
  @@map("chunk_page_mappings")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

/// One Agent HTTP session per platform user per course (B3 isolation).
model CourseChatSession {
  id             String   @id @default(uuid()) @db.Uuid
  courseId       String   @map("course_id") @db.Uuid
  studentId      String   @map("student_id") @db.Uuid
  agentSessionId String   @unique @map("agent_session_id") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([studentId])
  @@map("course_chat_sessions")
}

/// QA center global threads (cross-course RAG); one Agent session per row.
model QaCenterSession {
  id             String    @id @default(uuid()) @db.Uuid
  studentId      String    @map("student_id") @db.Uuid
  agentSessionId String    @unique @map("agent_session_id") @db.VarChar(255)
  title          String?   @map("title")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("qa_center_sessions")
}

/// Custom titles for course-scoped chat threads (keyed by agent session_id).
model ChatThreadTitleOverride {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  sessionId String   @map("session_id") @db.VarChar(255)
  title     String   @map("title")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId])
  @@index([studentId])
  @@map("chat_thread_title_overrides")
}

model QaLog {
  id                String    @id @default(uuid()) @db.Uuid
  courseId          String?   @map("course_id") @db.Uuid
  studentId         String    @map("student_id") @db.Uuid
  lessonId          String?   @map("lesson_id") @db.Uuid
  sessionId         String    @map("session_id") @db.VarChar(255)
  question          String    @map("question")
  questionTokens    Int?      @map("question_tokens")
  answer            String?   @map("answer")
  answerTokens      Int?      @map("answer_tokens")
  totalTokens       Int?      @map("total_tokens")
  executionTimeMs   Int       @map("execution_time_ms")
  modelUsed         String    @map("model_used") @db.VarChar(100)
  hitChunks         String[]  @default([]) @map("hit_chunks")
  hitMaterials      String[]  @default([]) @map("hit_materials")
  hitSources        String[]  @default([]) @map("hit_sources")
  toolCalls         Json?     @default("[]") @map("tool_calls")
  citations         Json?     @default("[]") @map("citations")
  responseQuality   Int?      @map("response_quality") @db.SmallInt
  isHelpful         Boolean?  @map("is_helpful")
  agentFeedback     String?   @map("agent_feedback")
  metadata          Json?     @map("metadata")
  createdAt         DateTime  @default(now()) @map("created_at")
  deletedAt         DateTime? @map("deleted_at")

  course  Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User    @relation("QaLogStudent", fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([courseId, createdAt(sort: Desc)])
  @@index([studentId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@map("qa_logs")
}

/// Teacher-created assignments generated by the AI pipeline.
model Assignment {
  id            String           @id @default(uuid()) @db.Uuid
  courseId      String           @map("course_id") @db.Uuid
  createdBy     String           @map("created_by") @db.Uuid
  title         String           @map("title")
  description   String?          @map("description")
  status        AssignmentStatus @default(GENERATING) @map("status")
  errorMessage  String?          @map("error_message")

  /// PlannerAgent output: {title, topic_hint, difficulty, count, type_weights, objective_weights, estimated_minutes}
  blueprint     Json?            @map("blueprint")

  /// Array of question objects: [{id, type, objective, entity, question, options, answer, explanation, score, ...}]
  questions     Json?            @map("questions")

  /// ReviewerAgent output: {overall_score, passed, threshold, question_reviews, failed_ids, summary}
  qualityReport Json?            @map("quality_report")

  deadline      DateTime?        @map("deadline")
  publishedAt   DateTime?        @map("published_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdByUser User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([courseId, status])
  @@index([courseId, createdAt(sort: Desc)])
  @@map("assignments")
}

model UserLearningProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  profile   Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_learning_profiles")
}

model UserMemoryFact {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  sessionId  String   @map("session_id")
  timestamp  DateTime @default(now())
  category   String
  content    String
  confidence Float
  sourceJson Json     @map("source_json")
  metadata   Json     @default("{}")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([userId, sessionId])
  @@map("user_memory_facts")
}

model UserMemoryConcept {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  name              String
  description       String   @default("")
  masteryLevel      Float    @default(0) @map("mastery_level")
  lastUpdated       DateTime @updatedAt @map("last_updated")
  supportingFactIds String[] @map("supporting_fact_ids")
  relatedConcepts   String[] @map("related_concepts")
  metadata          Json     @default("{}")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, name])
  @@index([userId])
  @@map("user_memory_concepts")
}

/// Scheduled agent tasks (cron / interval). Triggered via Redis Stream.
model CronJob {
  id          String    @id @db.VarChar(64)
  userId      String?   @map("user_id") @db.Uuid
  prompt      String
  /// 5-field cron expression (e.g. "0 8 * * *") or "every Xm/Xh/Xd"
  schedule    String
  /// "active" | "paused"
  status      String    @default("active")
  lastRunAt   DateTime? @map("last_run_at")
  nextRunAt   DateTime? @map("next_run_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  runs CronJobRun[]

  @@index([status, nextRunAt])
  @@index([userId])
  @@map("cron_jobs")
}

/// Individual execution records for a CronJob.
model CronJobRun {
  id           String    @id @default(uuid()) @db.Uuid
  jobId        String    @map("job_id") @db.VarChar(64)
  /// "running" | "success" | "failed"
  status       String    @default("running")
  output       String?
  toolCalls    Json?     @default("[]") @map("tool_calls")
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  errorMessage String?   @map("error_message")

  job CronJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, startedAt(sort: Desc)])
  @@map("cron_job_runs")
}
